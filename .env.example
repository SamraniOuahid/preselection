# ──────────────────────────────────────────────────────────────────────
# Variables d'environnement — ENSA BM Présélection Platform
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────────────────────────────

# ── Django ──────────────────────────────────────────────────────────
SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete-en-production
DEBUG=False
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com

# ── Base de données PostgreSQL ──────────────────────────────────────
USE_POSTGRES=True
DB_NAME=ensa_bm_db
DB_USER=ensa_user
DB_PASSWORD=changez-moi-mot-de-passe-fort
DB_HOST=db
DB_PORT=5432

# ── Redis (Channels WebSocket) ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Email (SMTP) ───────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-app-password

# ── Domaine (pour Nginx + Certbot) ─────────────────────────────────
DOMAIN_NAME=votre-domaine.com

# ── Certbot / Let's Encrypt ────────────────────────────────────────
CERTBOT_EMAIL=votre-email@gmail.com
